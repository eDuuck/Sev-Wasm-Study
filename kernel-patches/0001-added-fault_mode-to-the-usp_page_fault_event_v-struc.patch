From c04228efe02b469f05500b08c5ff57ce8d0d51e8 Mon Sep 17 00:00:00 2001
From: Markus Berthilsson <Markus.Berthilsson@eit.lth.se>
Date: Mon, 23 Jun 2025 13:52:51 +0200
Subject: [PATCH 1/3] added fault_mode to the usp_page_fault_event_v structure.
 Just 2 lines of code.

---
 arch/x86/kvm/mmu/mmu.c                 | 1 +
 include/uapi/linux/sev-step/sev-step.h | 1 +
 2 files changed, 2 insertions(+)

diff --git a/arch/x86/kvm/mmu/mmu.c b/arch/x86/kvm/mmu/mmu.c
index da811d3ba38b..dde13af13636 100644
--- a/arch/x86/kvm/mmu/mmu.c
+++ b/arch/x86/kvm/mmu/mmu.c
@@ -3965,6 +3965,7 @@ static bool page_fault_handle_page_track(struct kvm_vcpu *vcpu,
 		int send_ret = 0;
 		usp_page_fault_event_t pf_event = {
 			//.id = ,
+			.fault_mode = mode,
 			.faulted_gpa = (uint64_t)(fault->gfn << PAGE_SHIFT),
 			.is_decrypted_vmsa_data_valid = false,
 		};
diff --git a/include/uapi/linux/sev-step/sev-step.h b/include/uapi/linux/sev-step/sev-step.h
index 2ac1da1d8c01..c90e7da636e5 100644
--- a/include/uapi/linux/sev-step/sev-step.h
+++ b/include/uapi/linux/sev-step/sev-step.h
@@ -177,6 +177,7 @@ typedef struct {
 	// gpa of the page fault
 	uint64_t faulted_gpa;
 	sev_step_partial_vmcb_save_area_t decrypted_vmsa_data;
+	int fault_mode;
 	/// @brief if true, decrypted_vmsa_data contains valid data
 	bool is_decrypted_vmsa_data_valid;
 } usp_page_fault_event_t;
-- 
